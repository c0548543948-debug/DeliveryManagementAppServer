### ==================== ORDERS ====================

# GET All Orders
GET {{Web_HostAddress}}/api/Orders
Authorization: Bearer {{Token}}

###

# GET Order by ID
GET {{Web_HostAddress}}/api/Orders/1
Authorization: Bearer {{Token}}

###

# GET Validate Address
GET {{Web_HostAddress}}/api/Orders/validate-address?address=Dizengoff 10, Tel Aviv
Authorization: Bearer {{Token}}

###

# POST Calculate Price
POST {{Web_HostAddress}}/api/Orders/calculate-price
Authorization: Bearer {{Token}}
Content-Type: application/json

{
  "originAddress": "Dizengoff Street, Tel Aviv",
  "destinationAddress": "Ben Gurion Airport, Israel",
  "weight": 5,
  "volume": 2,
  "requiredDate": "2025-12-01T00:00:00Z"
}

###

# POST Create Order
POST {{Web_HostAddress}}/api/Orders
Authorization: Bearer {{Token}}
Content-Type: application/json

{
  "customerId": 1,
  "originAddress": "Dizengoff Street, Tel Aviv",
  "destinationAddress": "Ben Gurion Airport, Israel",
  "weight": 5,
  "volume": 2,
  "requiredDate": "2025-12-01T00:00:00Z"
}

###

# PUT Update Order
PUT {{Web_HostAddress}}/api/Orders/1
Authorization: Bearer {{Token}}
Content-Type: application/json

{
  "id": 1,
  "originAddress": "Dizengoff Street, Tel Aviv",
  "destinationAddress": "Ben Gurion Airport, Israel",
  "weight": 5,
  "volume": 2,
  "requiredDate": "2025-12-01T00:00:00Z",
  "price": 55.00,
  "status": 0
}

###

# DELETE Order
DELETE {{Web_HostAddress}}/api/Orders/1
Authorization: Bearer {{Token}}

###

